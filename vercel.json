{
    "version": 2,
    "builds": [
        {
            "src": "api/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "web-react/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/web-react/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/web-react/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/admin/daily-report",
            "schedule": "45 23 * * *"
        }
    ]
}