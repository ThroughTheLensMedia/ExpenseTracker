{
    "version": 2,
    "builds": [
        {
            "src": "api/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "web-react/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "web-react/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "web-react/dist/index.html"
        }
    ]
}