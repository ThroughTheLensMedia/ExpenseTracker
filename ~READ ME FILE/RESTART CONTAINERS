###API health check commands###
# From project root
cd /volume1/docker/expense-tracker

# Show container state
sudo docker ps --format "table {{.Names}}\t{{.Status}}"

# Show compose service state (if supported)
sudo docker compose -f compose.yml --env-file .env ps


##API health (3 ways)
#A) Inside the docker network (most reliable)
sudo docker exec -it expense_web sh -lc 'wget -qO- http://expense_api:3000/health && echo'

#B) API container loopback
sudo docker exec -it expense_api sh -lc 'wget -qO- http://127.0.0.1:3000/health && echo'

#C) Through the public site path (will redirect to Cloudflare Access if not logged in)
curl -sS -D - https://tracker.throughthelens.media/api/health -o /dev/null | head -n 20

#	•	200 means good (and you’re authenticated)
#	•	302 to cloudflareaccess.com/.../login is normal if not authenticated


